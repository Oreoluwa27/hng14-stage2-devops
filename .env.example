# ====================================
# Application Configuration
# ====================================

ENVIRONMENT=production
LOG_LEVEL=info

# ====================================
# Frontend Configuration
# ====================================

FRONTEND_PORT=3000
REACT_APP_BACKEND_URL=http://backend:8000
BACKEND_URL=http://backend:8000

# ====================================
# Backend Configuration
# ====================================

BACKEND_PORT=8000

# ====================================
# Redis Configuration
# ====================================

REDIS_VERSION=7
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=supersecretpassword123
REDIS_APPENDONLY=yes
REDIS_DATA_PATH=/data

# ====================================
# Resource Limits (CPU & Memory)
# ====================================

# Frontend Resources
FRONTEND_CPU_LIMIT=0.5
FRONTEND_MEMORY_LIMIT=256M
FRONTEND_CPU_RESERVE=0.25
FRONTEND_MEMORY_RESERVE=128M

# Backend Resources
BACKEND_CPU_LIMIT=1
BACKEND_MEMORY_LIMIT=512M
BACKEND_CPU_RESERVE=0.5
BACKEND_MEMORY_RESERVE=256M

# Worker Resources
WORKER_CPU_LIMIT=0.5
WORKER_MEMORY_LIMIT=256M
WORKER_CPU_RESERVE=0.25
WORKER_MEMORY_RESERVE=128M

# Redis Resources
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=256M
REDIS_CPU_RESERVE=0.25
REDIS_MEMORY_RESERVE=128M

# ====================================
# Logging Configuration
# ====================================

LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# ====================================
# Network Configuration
# ====================================

NETWORK_SUBNET=172.25.0.0/16

# ====================================
# Add Your Secrets Below
# (Fetch from secret manager in production)
# ====================================

# API_KEY=your_api_key_here
# DB_PASSWORD=your_db_password_here
# SECRET_TOKEN=your_secret_token_here
